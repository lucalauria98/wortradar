# WortRadar – Streamlit Secrets Vorlage
# Kopieren nach .streamlit/secrets.toml (lokal) ODER direkt in Streamlit Cloud
# unter "App settings > Secrets" einfuegen.
# Die Datei secrets.toml selbst ist in .gitignore – niemals pushen!

# ── Supabase Auth ───────────────────────────────────────────────────────────
SUPABASE_URL      = "https://DEIN-PROJEKT.supabase.co"
SUPABASE_ANON_KEY = "eyJ..."   # Project Settings > API > anon public

# ── Supabase Postgres (fuer Nutzerdaten) ────────────────────────────────────
# Project Settings > Database > Connection string > URI (Transaction Pooler)
# Format: postgresql://postgres.XXXX:PASSWORT@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL = "postgresql://postgres.XXXX:PASSWORT@aws-0-REGION.pooler.supabase.com:6543/postgres"

# ── KI-Uebersetzung (mindestens einen Key setzen) ───────────────────────────
GROQ_API_KEY      = ""   # empfohlen – kostenlos auf console.groq.com
GEMINI_API_KEY    = ""   # alternativ – aistudio.google.com
ANTHROPIC_API_KEY = ""   # alternativ
